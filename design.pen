                "ahPy7": {
                  "content": "ACTIVE"
                },
                "trhrj": {
                  "content": "Omnicado",
                  "fontSize": 36
                },
                "NqOI0": {
                  "content": "The omnichannel platform that connects online sellers to 800+ marketplaces and channels — Alza, Allegro, Kaufland, Amazon and more — handling listings, pricing, stock and orders in one place. 250+ clients, official integrator for the major CEE marketplaces.",
                  "fontSize": 18
                },
                "FyvLj": {
                  "content": "omnicado.com"
                }
              }
            },
            {
              "type": "frame",
