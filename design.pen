              "children": [
                {
                  "id": "btNUA",
                  "type": "ref",
                  "ref": "KRiWh",
                  "name": "Atoto",
                  "width": "fill_container",
                  "descendants": {
                    "wRCNU": {
                      "content": "CEO · 2017–2019"
                    },
                    "ahPy7": {
                      "content": "ACQUIRED"
                    },
                    "trhrj": {
                      "content": "Atoto.cz"
                    },
                    "NqOI0": {
                      "content": "An online-grocery price comparison I took over as CEO and pivoted into a marketplace with delivery — scaling it from around 40 orders a month to 250 a day before it was acquired."
                    },
                    "x3NWR": {
                      "enabled": false
                    },
